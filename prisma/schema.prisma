// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int                 @id @default(autoincrement())
  username           String              @db.VarChar(250)
  alias              String              @default("Chest wizard") @db.VarChar(255)
  chestPads          ChestPad[]
  dashboards         Dashboard[]
  connections        Connection[]        @relation("ConnectionFromUser")
  connectedToMe      Connection[]        @relation("ConnectionToUser")
  connectionRequests ConnectionRequest[]
}

model Dashboard {
  id       Int        @id @default(autoincrement())
  name     String     @db.VarChar(100)
  dashRank String     @db.VarChar(16)
  userId   Int
  user     User       @relation(fields: [userId], references: [id])
  chestPads ChestPad[]

  @@index([userId, dashRank])
}

model Chest {
  id        Int       @id @default(autoincrement())
  label     String    @db.VarChar(100)
  createdAt DateTime  @default(now())
  carrots   Carrot[]
  chestPads ChestPad[]
}

model ChestPad {
  id       Int    @id @default(autoincrement())
  status   Status @default(NEW)
  pinned   Boolean @default(false)
  shared   Shared @default(NO)
  dashRank String @db.VarChar(16)

  userId Int
  user User @relation(fields: [userId], references: [id])

  chestId Int
  chest Chest @relation(fields: [chestId], references: [id])

  dashboardId Int
  dashboard Dashboard @relation(fields: [dashboardId], references: [id])

  @@index([userId, dashRank])
  @@index([chestId])
  @@index([dashboardId])
}

model Connection {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  alias String @db.VarChar(255)

  userId Int
  user User @relation("ConnectionFromUser", fields: [userId], references: [id])

  connectionUserId Int
  connectionUser User @relation("ConnectionToUser", fields: [connectionUserId], references: [id])

  @@unique([userId, connectionUserId])
  @@index([connectionUserId])
}

model ConnectionRequest {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model Carrot {
  id        Int  @id @default(autoincrement())
  label     String  @db.VarChar(255)
  harvested Boolean @default(false)

  chestId Int
  chest   Chest @relation(fields: [chestId], references: [id])
}

enum Status {
  NEW
  ARCHIVED
}

enum Shared {
  NO
  SHARED
  UNSHARED
}
